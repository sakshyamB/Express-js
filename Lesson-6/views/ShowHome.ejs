<!DOCTYPE html>
<html>

<head>
    <title>All Hotels</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="p-5 bg-gray-100">

    <h1 class="text-2xl font-bold mb-5">All Hotels</h1>

    <div class="grid grid-cols-3 gap-4">

        <% if (hotels && hotels.length > 0) { %>

            <% hotels.forEach(hotel => { %>

                <div class="border p-4 rounded shadow bg-white">

                    <h2 class="text-xl font-semibold">
                        <%= hotel.name %>
                    </h2>

                    <p>📍 Location: <%= hotel.location %></p>
                    <p>💰 Price: Rs <%= hotel.price %></p>
                    <p>⭐ Rating: <%= hotel.rating %></p>

                    <a class="w-fit bg-blue-500 text-white px-3 py-1 rounded inline-block mt-2"
                        href="/ShowHome/<%= hotel.id %>">
                        Show Details
                    </a>

                    <% if (!hotel.favourite) { %>

                        <a href="/Favourite/<%= hotel.id %>"
                            class="bg-red-500 text-white px-3 py-1 rounded inline-block mt-2">
                            Add to Favourite
                        </a>

                    <% } else { %>

                        <a href="/Favourite/<%= hotel.id %>"
                            class="bg-green-500 text-white px-3 py-1 rounded inline-block mt-2">
                            Added to Favourite
                        </a>

                    <% } %>

                </div>

            <% }) %>

        <% } else { %>

            <p>No hotels available</p>

        <% } %>

    </div>

</body>

</html>