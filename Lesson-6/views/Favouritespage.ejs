<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Favourites</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="p-5 bg-gray-100">

    <h1 class="text-3xl font-bold mb-5">
        These are your favourite hotels
    </h1>

    <div class="grid grid-cols-3 gap-4">

        <% if (FavouriteHotels && FavouriteHotels.length > 0) { %>

            <% FavouriteHotels.forEach(hotel => { %>

                <div class="border p-4 rounded shadow bg-white">

                    <h2 class="text-xl font-bold">
                        <%= hotel.name %>
                    </h2>

                    <p>📍 <%= hotel.location %></p>
                    <p>💰 Rs <%= hotel.price %></p>
                    <p>⭐ <%= hotel.rating %></p>

                    <a
                        href="/favourite/<%= hotel.id %>"
                        class="bg-red-500 text-white px-3 py-1 rounded inline-block mt-2"
                    >
                        Remove from Favourite
                    </a>

                </div>

            <% }) %>

        <% } else { %>

            <p>No favourite hotels yet.</p>

        <% } %>

    </div>

</body>

</html>